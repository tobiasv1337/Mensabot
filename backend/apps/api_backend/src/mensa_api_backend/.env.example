LLM_BASE_URL=https://chat-ai.academiccloud.de/v1
LLM_MODEL=meta-llama-3.1-8b-instruct
LLM_API_KEY=INSERT_API_KEY_HERE
MCP_URL=http://localhost:8000/mcp
LLM_SUPPORTS_TOOL_MESSAGES=true # Set to true for any specification conform LLM. Set to false for SAIA which seems to have issues with multi-tool requests.
MAX_LLM_ITERATIONS=10
LOG_LEVEL=INFO
LLM_MAX_RETRIES=10
LLM_RETRY_BASE_DELAY=1.0
LLM_RETRY_MAX_DELAY=30.0