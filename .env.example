
# ==========================================
# [CATEGORY] Nginx / Basic Auth
# Configure basic authentication to protect your Mensabot deployment.
# ==========================================
# Username for accessing the Mensabot deployment.
# Leave empty to disable basic auth.
BASIC_AUTH_USER=

# Password for accessing the Mensabot deployment.
# Leave empty to disable basic auth.
BASIC_AUTH_PASS=


# ==========================================
# [CATEGORY] Frontend
# Settings for the React frontend application.
# ==========================================
# Base URL for the API.
# Use "/api" for both Docker (Nginx) and Local Dev (Vite Proxy).
VITE_API_BASE_URL=/api

# ==========================================
# [CATEGORY] MapTiler (Map Page)
# Mensabot expects TWO published MapTiler Style JSON URLs:
# one for Light Mode and one for Dark Mode.
#
# Recommended setup:
# 1. Create a free account at https://www.maptiler.com/cloud/
# 2. Open MapTiler Map Designer.
# 3. Start from one of the official default styles (recommended):
#    - Light Mode: based on a bright/default light style
#    - Dark Mode: based on a dark style
# 4. Duplicate the default style so you create your OWN custom style.
# 5. Customize the style for Mensabot, for example:
#    - reduce or disable unnecessary POIs to make the map less cluttered
#    - keep useful labels such as streets, public transport, and campuses if desired
#    - enable 3D buildings / 3D view if you want a richer map appearance
#    - adjust colors so Light and Dark mode clearly match your frontend theme
# 6. Publish each custom style.
# 7. Open each published style and copy its "Style JSON" / vector style URL.
# 8. Paste the FULL published custom style URL below.
#
# Important:
# - Do not use the raw default built-in style unless you intentionally want MapTiler's
#   unmodified look.
# - Use your own published custom styles for both themes.
# - Copy the Style JSON URL exactly as provided by MapTiler.

# Suggested customization for both styles:
# - Disable most POI layers unless they are relevant for Mensa users
# - Keep building footprints visible
# - Enable 3D buildings if you want perspective/tilt-based viewing
# - Avoid overly noisy label density
# ==========================================
# Full Style JSON URLs including map style and key
# The URL for the light theme of the map.
VITE_MAPTILER_STYLE_URL_LIGHT=
# The URL for the dark theme of the map.
VITE_MAPTILER_STYLE_URL_DARK=

# ==========================================
# [CATEGORY] API Backend (LLM Settings)
# Configuration for the LLM Provider and Core Backend Behavior.
# ==========================================
# Base URL for the LLM provider API (for example OpenRouter, OpenAI-compatible endpoints, or a local server like Ollama or llama.cpp with OpenAI-compatible endpoints)
API_BACKEND_LLM_BASE_URL=https://openrouter.ai/api/v1
# Exact model identifier used by the backend
API_BACKEND_LLM_MODEL=qwen/qwen3.5-27b
# API key for the configured LLM provider
API_BACKEND_LLM_API_KEY=INSERT_API_KEY_HERE
# Maximum number of subsequent tool calls the LLM is allowed to make before forcing a response.
API_BACKEND_MAX_LLM_ITERATIONS=30
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
API_BACKEND_LOG_LEVEL=INFO
# Maximum number of automatic retries if the LLM API fails or times out.
API_BACKEND_LLM_MAX_RETRIES=10
# Base backoff delay in seconds between retries.
API_BACKEND_LLM_RETRY_BASE_DELAY=1.0
# Maximum total delay in seconds for backing off during retries.
API_BACKEND_LLM_RETRY_MAX_DELAY=30.0
# Max concurrent connections for internal IO network tasks.
API_BACKEND_IO_MAX_CONCURRENCY=10
# Max concurrent active connections towards your LLM API.
API_BACKEND_LLM_MAX_CONCURRENCY=10
# Enable JSON debug endpoint at /api/debug/metrics (cache + external API call counters)
API_BACKEND_ENABLE_DEBUG_ENDPOINTS=false

# ==========================================
# [CATEGORY] Voice / STT Service
# Settings for the Whisper Speech-to-Text transcriber.
# ==========================================
# Base URL for the local STT service (Docker service name).
API_BACKEND_STT_BASE_URL=http://stt:9100
# Max duration in seconds to wait for STT transcriptions to complete before timing out.
API_BACKEND_STT_TIMEOUT_S=900
# Max size in bytes for audio uploads sent to the STT API.
API_BACKEND_STT_MAX_UPLOAD_BYTES=26214400
# Ensure only 1 active transcription runs at a time to prevent resource exhaustion.
API_BACKEND_STT_MAX_CONCURRENCY=1

# STT service configuration (whisper.cpp)
# Define the size of the local Whisper model (e.g. tiny, base, small, medium).
# Larger models are more accurate but use heavily more system memory and processor time.
# NOTE: Models ending with ".en" are English-only (e.g. base.en, small.en). For German (and
# other languages), use the multilingual variants without ".en" (e.g. base, small, medium).
STT_MODEL=small
# Language passed to whisper.cpp. Use "auto" for auto-detect.
STT_LANGUAGE=auto
# If true, the STT service will download the ggml model file into /models on startup/request if missing.
STT_AUTO_DOWNLOAD_MODEL=true
# Define CPU threads dedicated to transcription processing. Ensure this matches your VM's thread count for optimal speed.
STT_THREADS=4
# Maximum expected length of a single transcribed voice audio upload in seconds.
STT_MAX_AUDIO_SECONDS=180
# Max size in bytes for audio uploads accepted by the external ingestion container.
STT_MAX_UPLOAD_BYTES=26214400

# ==========================================
# [CATEGORY] MCP Server (OpenMensa / Map)
# Configuration for the external data providers.
# ==========================================
# Base URL to fetch canteens.
MENSA_MCP_OPENMENSA_BASE_URL=https://openmensa.org/api/v2
# Timeout parameter for fetching canteens.
MENSA_MCP_OPENMENSA_TIMEOUT=10.0
# The HTTP Header User agent passed via GET requests to the OpenMensa APIs.
MENSA_MCP_OPENMENSA_USER_AGENT=mensabot-mcp-server/0.1
# Identify the Model Context Protocol internal system server name to the LLM agent.
MENSA_MCP_MCP_NAME=mensabot-openmensa-mcp-server

# OpenStreetMaps overpass geometry URL base path.
MENSA_MCP_OVERPASS_URL=https://overpass-api.de/api/interpreter
# Time definition in seconds before marking a overpass API call as failed.
MENSA_MCP_OVERPASS_TIMEOUT=25.0
# Define how long (in seconds) the MCP backend should aggressively cache the relatively expensive routing coordinate geometry responses.
MENSA_MCP_OVERPASS_CACHE_TTL_S=900
# User Agent Header string while communicating to Overpass for geometries fetching.
MENSA_MCP_OVERPASS_USER_AGENT=mensabot-mcp-server/0.1

# Cache file placement where the internal search index saves the parsed list of ALL possible canteen institutions.
# Note: For Docker deployment, `docker-compose.yml` automatically overrides this to `/data/canteens.json` to persist it in a volume.
# For local development without Docker, leave this blank to use memory or a local temp file.
MENSA_MCP_CANTEEN_INDEX_PATH=
# The duration (Hours) to keep the internal pre-computed search indices active before re-syncing from OpenMensa API upstream.
MENSA_MCP_CANTEEN_INDEX_TTL_HOURS=24.0

# System time configuration. Needed for identifying the current date/locale accurately.
MENSA_MCP_TIMEZONE=Europe/Berlin
# IO networking operations simultaneous maximum constraints towards OpenMensa map lookups internally.
MENSA_MCP_IO_MAX_CONCURRENCY=10
