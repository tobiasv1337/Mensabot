
# ==========================================
# Nginx / Basic Auth
# ==========================================
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=secret

# ==========================================
# Frontend
# ==========================================
# Base URL for the API.
# Use "/api" for both Docker (Nginx) and Local Dev (Vite Proxy).
VITE_API_BASE_URL=/api

# MapTiler (Map Page)
# Full Style JSON URLs including map style and key
VITE_MAPTILER_STYLE_URL_LIGHT=
VITE_MAPTILER_STYLE_URL_DARK=

# ==========================================
# Backend: API Server
# ==========================================
API_BACKEND_LLM_BASE_URL=https://openrouter.ai/api/v1
API_BACKEND_LLM_MODEL=openai/gpt-oss-20b
API_BACKEND_LLM_API_KEY=INSERT_API_KEY_HERE
API_BACKEND_LLM_SUPPORTS_TOOL_MESSAGES=true
API_BACKEND_MAX_LLM_ITERATIONS=30
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
API_BACKEND_LOG_LEVEL=INFO
API_BACKEND_LLM_MAX_RETRIES=10
API_BACKEND_LLM_RETRY_BASE_DELAY=1.0
API_BACKEND_LLM_RETRY_MAX_DELAY=30.0
API_BACKEND_IO_MAX_CONCURRENCY=10
API_BACKEND_LLM_MAX_CONCURRENCY=10

# ==========================================
# Backend: MCP Server (OpenMensa)
# ==========================================
MENSA_MCP_OPENMENSA_BASE_URL=https://openmensa.org/api/v2
MENSA_MCP_OPENMENSA_TIMEOUT=10.0
MENSA_MCP_OPENMENSA_USER_AGENT=mensabot-mcp-server/0.1
MENSA_MCP_MCP_NAME=mensabot-openmensa-mcp-server

MENSA_MCP_OVERPASS_URL=https://overpass-api.de/api/interpreter
MENSA_MCP_OVERPASS_TIMEOUT=25.0
MENSA_MCP_OVERPASS_CACHE_TTL_S=900
MENSA_MCP_OVERPASS_USER_AGENT=mensabot-mcp-server/0.1

MENSA_MCP_CANTEEN_INDEX_PATH=
MENSA_MCP_CANTEEN_INDEX_TTL_HOURS=24.0

MENSA_MCP_TIMEZONE=Europe/Berlin
MENSA_MCP_IO_MAX_CONCURRENCY=10
